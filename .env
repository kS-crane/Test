# spaceman-analytics build configuration
# These values are used during CI builds and local development.

# Build mode: controls minification and source maps
BUILD_MODE=production

# Bundle analysis: set to "true" to emit detailed size reports
BUNDLE_REPORT=true

# API endpoint for telemetry during integration tests
TELEMETRY_ENDPOINT=https://telemetry.spaceman-analytics.dev/v1

# Feature flags
ENABLE_TREE_SHAKING=true
ENABLE_SOURCE_MAPS=false

# Cache TTL for CI builds (seconds)
CI_CACHE_TTL=3600
